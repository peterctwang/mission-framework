# Copy to .env and fill in. .env is gitignored.

# Required for the Minimax provider only. Other providers use CLI OAuth
# (claude login / codex login / gemini OAuth) so no key is needed.
MINIMAX_API_KEY=sk-cp-your-minimax-coding-plan-key-here

# Optional overrides
# MINIMAX_MODEL=MiniMax-M2.5
# MINIMAX_API_URL=https://api.minimax.io/v1/chat/completions
